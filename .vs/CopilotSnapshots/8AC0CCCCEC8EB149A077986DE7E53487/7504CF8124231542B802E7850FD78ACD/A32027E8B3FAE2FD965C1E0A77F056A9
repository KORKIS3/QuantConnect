"""
Remove timezone offset and create separate Time column
Save as UpdatedJanData.csv on desktop
"""
import pandas as pd
import os

# Load the data
input_csv = os.path.join(os.path.expanduser('~'), 'Desktop', 'YM_Jan26_HLC.csv')
output_csv = os.path.join(os.path.expanduser('~'), 'Desktop', 'UpdatedJanData.csv')

print("="*60)
print("Removing Timezone Offset & Creating Time Column")
print("="*60)
print(f"\nReading: {input_csv}")

df = pd.read_csv(input_csv, parse_dates=['Timestamp'])

print(f"Loaded {len(df):,} rows")
print(f"\nBefore (with timezone):")
print(df.head(3))

# Remove timezone by converting to naive datetime
df['Timestamp'] = pd.to_datetime(df['Timestamp']).dt.tz_localize(None)

# Create separate Date and Time columns
df['Date'] = df['Timestamp'].dt.date
df['Time'] = df['Timestamp'].dt.strftime('%H:%M:%S')

# Reorder columns: Timestamp, Date, Time, High, Low, Close
df = df[['Timestamp', 'Date', 'Time', 'High', 'Low', 'Close']]

print(f"\nAfter (no timezone, with separate Time column):")
print(df.head(10))

# Save to desktop
df.to_csv(output_csv, index=False)

print("\n" + "="*60)
print("VERIFICATION")
print("="*60)

# Show morning trading hours (09:30)
print("\nMorning trading (09:30-09:40):")
morning = df[df['Time'].between('09:30:00', '09:40:00')]
if not morning.empty:
    print(morning.head(10).to_string(index=False))
else:
    print("  (No 9:30 data found)")

# Show primary window (10:00-10:10)
print("\nPrimary window (10:00-10:10):")
primary = df[df['Time'].between('10:00:00', '10:10:00')]
if not primary.empty:
    print(primary.head(10).to_string(index=False))

print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Total rows: {len(df):,}")
print(f"Columns: {df.columns.tolist()}")
print(f"Date range: {df['Date'].iloc[0]} to {df['Date'].iloc[-1]}")
print(f"Time format: HH:MM:SS (no timezone offset)")
print(f"\n✓ Saved to: {output_csv}")
print("="*60)
