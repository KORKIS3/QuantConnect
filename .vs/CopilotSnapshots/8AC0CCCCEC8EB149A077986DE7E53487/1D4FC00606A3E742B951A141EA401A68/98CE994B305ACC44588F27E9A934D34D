"""TradingAlgo

Trading algorithm core.

This module wraps the existing signal-detection logic that lives in
`plotFigure.ChartPlotter` so it can be called in a data-first way.

Design goals:
- Accept a minute-by-minute YM DataFrame for a single day.
- Run all existing ray / signal detection minute-by-minute (no UI).
- Return a new DataFrame with the original OHLC data plus per-minute
  signal and P/L information.

IMPORTANT: Per user request, logic is *not* moved out of
`plotFigure.py`; we reuse it via imports instead of cutting code.
"""

from typing import Optional

import os
import pandas as pd

from plotFigure import ChartPlotter


def _build_signals_frame(plotter: ChartPlotter) -> pd.DataFrame:
    """Construct a per-minute DataFrame from a populated ChartPlotter.

    The returned DataFrame has the same index as `plotter.data` and
    includes:
    - Original OHLC columns.
    - `signal`: "BUY", "SELL", or "" per minute.
    - `buy_price` / `sell_price`: prices at signal times.
    - `position`: "flat" | "long" | "short" after processing the
      current minute.
    - `pl`: cumulative P/L at that minute (realized + unrealized),
      matching the logic used in the top P/L axis.
    """

    df = plotter.data.copy()

    # Base signal columns
    df["signal"] = ""
    df["buy_price"] = pd.NA
    df["sell_price"] = pd.NA

    buy_signals = plotter.state.detected_buy_signals
    sell_signals = plotter.state.detected_sell_signals

    for ts, price in buy_signals.items():
        if ts in df.index:
            df.at[ts, "signal"] = "BUY"
            df.at[ts, "buy_price"] = float(price)

    for ts, price in sell_signals.items():
        if ts in df.index:
            # If both BUY and SELL exist at the same ts, SELL wins here
            # but the raw dictionaries are still available on `plotter`.
            df.at[ts, "signal"] = "SELL"
            df.at[ts, "sell_price"] = float(price)

    # Reconstruct position and cumulative P/L using the same rules as
    # `ChartPlotter.update_pl_axis`.
    position = "flat"
    entry_price: Optional[float] = None
    cumulative_realized_pl: float = 0.0

    positions = []
    pls = []

    for ts in df.index:
        if plotter.state.trading_halted and plotter.state.halt_time is not None and ts > plotter.state.halt_time:
            # After halt, keep position flat and P/L constant.
            positions.append("flat")
            pls.append(cumulative_realized_pl)
            continue

        is_buy = ts in buy_signals
        is_sell = ts in sell_signals

        # Close existing position first (realize P/L), then open new one.
        if is_buy:
            buy_price = float(buy_signals[ts])
            if position == "short" and entry_price is not None:
                cumulative_realized_pl += entry_price - buy_price
            position = "long"
            entry_price = buy_price

        if is_sell:
            sell_price = float(sell_signals[ts])
            if position == "long" and entry_price is not None:
                cumulative_realized_pl += sell_price - entry_price
            position = "short"
            entry_price = sell_price

        current_close = float(df.loc[ts, "Close"])
        unrealized = 0.0
        if position == "long" and entry_price is not None:
            unrealized = current_close - entry_price
        elif position == "short" and entry_price is not None:
            unrealized = entry_price - current_close

        total_pl = cumulative_realized_pl + unrealized
        positions.append(position)
        pls.append(total_pl)

    df["position"] = positions
    df["pl"] = pls

    return df


def run_trading_algo(
    data: pd.DataFrame,
    target_date: str,
    start_time: str = "09:30",
    end_time: str = "10:00",
    output_dir: Optional[str] = None,
) -> pd.DataFrame:
    """Run the full trading algorithm for a single day's intraday data.

    This function:
    1. Creates a `ChartPlotter` in batch mode (no UI shown).
    2. Steps through every minute, letting the existing
       `update_signals_incremental` logic fire.
    3. Builds and returns a per-minute DataFrame with signals and P/L.
    """

    if data is None or data.empty:
        raise ValueError("run_trading_algo expected non-empty intraday data")

    if output_dir is None:
        # Reuse the same default directory as the interactive plotter.
        output_dir = os.path.join(os.path.expanduser("~"), "Desktop", "Trading", "Temp")

    os.makedirs(output_dir, exist_ok=True)

    # Create the existing ChartPlotter in batch mode so snapshots are
    # suppressed and no window is shown.
    plotter = ChartPlotter(data, target_date, start_time, end_time, output_dir, batch_mode=True)

    # We still need a figure/axes because the ray logic depends on
    # aspect ratio; we just do not call `plt.show()`.
    plotter.create_figure()
    plotter.fig.canvas.draw()

    # Step through each frame to trigger `update_signals_incremental`.
    for frame in range(len(data)):
        plotter.update_plot(frame)
        if plotter.state.trading_halted:
            break

    # Build and return the signals DataFrame.
    return _build_signals_frame(plotter)

