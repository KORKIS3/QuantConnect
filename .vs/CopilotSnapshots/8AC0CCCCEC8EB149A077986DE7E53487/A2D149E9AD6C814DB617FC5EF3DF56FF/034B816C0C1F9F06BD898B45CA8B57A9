    def update_plot(self, frame):
        """Main update function for each frame"""
        frame = max(0, min(frame, len(self.data) - 1))
        current_data = self.data.iloc[:frame + 1]
        
        if len(current_data) == 0:
            return
        
        x_per_inch, y_per_inch = self.get_aspect_ratio()
        
        if frame >= 0:
            if self.ray_manager.orange_ray is None:
                self.ray_manager.initialize_rays(current_data, x_per_inch, y_per_inch)
            
            self.ray_manager.update_yellow_ray_for_new_min(current_data, self.yellow_adjustment_cutoff, x_per_inch, y_per_inch)
            self.ray_manager.update_steep_rays(current_data, x_per_inch, y_per_inch)
        
        self.update_price_lines(current_data)
        self.update_ray_lines(current_data, x_per_inch, y_per_inch)
        self.update_annotations(current_data, x_per_inch, y_per_inch)
        self.update_signal_markers(current_data)
        self.update_stats(current_data)
        self.update_pl_axis(current_data)
        self.save_snapshot(current_data)

    def update_price_lines(self, current_data):
        """Update the price line data"""
        times = current_data.index
        self.lines['high'].set_data(times, current_data['High'])
        self.lines['low'].set_data(times, current_data['Low'])
        self.lines['close'].set_data(times, current_data['Close'])
    
    def update_ray_lines(self, current_data, x_per_inch, y_per_inch):
        """Update all ray lines"""
        if self.ray_manager.orange_ray is None:
            return
        
        end_time = self.data.index[-1]
        
        orange_slope = self.ray_manager.orange_ray.calculate_slope(x_per_inch, y_per_inch)
        orange_end = self.ray_manager.orange_ray.get_price_at_time(end_time, orange_slope)
        self.lines['ray_orange'].set_data([self.ray_manager.orange_ray.start_time, end_time],
                                          [self.ray_manager.orange_ray.start_price, orange_end])
        
        yellow_slope = self.ray_manager.yellow_ray.calculate_slope(x_per_inch, y_per_inch)
        yellow_end = self.ray_manager.yellow_ray.get_price_at_time(end_time, yellow_slope)
        self.lines['ray_yellow'].set_data([self.ray_manager.yellow_ray.start_time, end_time],
                                          [self.ray_manager.yellow_ray.start_price, yellow_end])
        
        purple_slope = self.ray_manager.purple_ray.adjusted_slope or self.ray_manager.purple_ray.calculate_slope(x_per_inch, y_per_inch)
        purple_end = self.ray_manager.purple_ray.get_price_at_time(end_time, purple_slope)
        self.lines['ray_purple'].set_data([self.ray_manager.purple_ray.start_time, end_time],
                                          [self.ray_manager.purple_ray.start_price, purple_end])
        
        blue_slope = self.ray_manager.blue_ray.adjusted_slope or self.ray_manager.blue_ray.calculate_slope(x_per_inch, y_per_inch)
        blue_end = self.ray_manager.blue_ray.get_price_at_time(end_time, blue_slope)
        self.lines['ray_blue'].set_data([self.ray_manager.blue_ray.start_time, end_time],
                                        [self.ray_manager.blue_ray.start_price, blue_end])
    
    def update_annotations(self, current_data, x_per_inch, y_per_inch):
        """Update all text annotations"""
        for ann in self.annotations:
            ann.remove()
        self.annotations.clear()
        
        for i, (time, row) in enumerate(current_data.iterrows()):
            time_str = time.strftime('%H:%M')
            
            ann = self.ax.annotate(f"{row['High']:.0f}\n{time_str}", xy=(time, row['High']),
                                  xytext=(0, 8), textcoords='offset points', ha='center', va='bottom',
                                  fontsize=6, color='darkgreen', fontweight='bold',
                                  bbox=dict(boxstyle='round,pad=0.3', facecolor='lightgreen', alpha=0.6, edgecolor='green'))
            self.annotations.append(ann)
            
            ann = self.ax.annotate(f"{row['Low']:.0f}\n{time_str}", xy=(time, row['Low']),
                                  xytext=(0, -8), textcoords='offset points', ha='center', va='top',
                                  fontsize=6, color='darkred', fontweight='bold',
                                  bbox=dict(boxstyle='round,pad=0.3', facecolor='lightcoral', alpha=0.6, edgecolor='red'))
            self.annotations.append(ann)
            
            ann = self.ax.annotate(f"{row['Close']:.0f}\n{time_str}", xy=(time, row['Close']),
                                  xytext=(5, 0), textcoords='offset points', ha='left', va='center',
                                  fontsize=6, color='black', fontweight='bold',
                                  bbox=dict(boxstyle='round,pad=0.3', facecolor='lightgray', alpha=0.6, edgecolor='black'))
            self.annotations.append(ann)
    
    def update_signal_markers(self, current_data):
        """Update buy and sell signal markers"""
        for marker in self.signal_markers['buy'] + self.signal_markers['sell']:
            marker.remove()
        for ann in self.signal_annotations['buy'] + self.signal_annotations['sell']:
            ann.remove()
        
        self.signal_markers = {'buy': [], 'sell': []}
        self.signal_annotations = {'buy': [], 'sell': []}
        
        for buy_time, buy_price in self.state.detected_buy_signals.items():
            if buy_time <= current_data.index[-1]:
                marker, = self.ax.plot(buy_time, buy_price, marker='^', markersize=15,
                                      color='green', markeredgecolor='darkgreen', markeredgewidth=2, zorder=10)
                self.signal_markers['buy'].append(marker)
                
                ann = self.ax.annotate(f"BUY\n{buy_price:.0f}\n{buy_time.strftime('%H:%M')}",
                                      xy=(buy_time, buy_price), xytext=(0, 30), textcoords='offset points',
                                      ha='center', va='bottom', fontsize=8, color='white', fontweight='bold',
                                      bbox=dict(boxstyle='round,pad=0.5', facecolor='green', alpha=0.9,
                                              edgecolor='darkgreen', linewidth=2),
                                      arrowprops=dict(arrowstyle='->', color='green', lw=2))
                self.signal_annotations['buy'].append(ann)
        
        for sell_time, sell_price in self.state.detected_sell_signals.items():
            if sell_time <= current_data.index[-1]:
                marker, = self.ax.plot(sell_time, sell_price, marker='v', markersize=15,
                                      color='red', markeredgecolor='darkred', markeredgewidth=2, zorder=10)
                self.signal_markers['sell'].append(marker)
                
                ann = self.ax.annotate(f"SELL\n{sell_price:.0f}\n{sell_time.strftime('%H:%M')}",
                                      xy=(sell_time, sell_price), xytext=(0, -30), textcoords='offset points',
                                      ha='center', va='top', fontsize=8, color='white', fontweight='bold',
                                      bbox=dict(boxstyle='round,pad=0.5', facecolor='red', alpha=0.9,
                                              edgecolor='darkred', linewidth=2),
                                      arrowprops=dict(arrowstyle='->', color='red', lw=2))
                self.signal_annotations['sell'].append(ann)
    
    def update_stats(self, current_data):
        """Update statistics box"""
        times = current_data.index
        current_time_str = times[-1].strftime('%H:%M')
        
        max_high = current_data['High'].max()
        min_low = current_data['Low'].min()
        max_time = current_data['High'].idxmax().strftime('%H:%M')
        min_time = current_data['Low'].idxmin().strftime('%H:%M')
        price_change = current_data['Close'].iloc[-1] - current_data['Close'].iloc[0]
        
        stats_text = f"Minute: {len(current_data)}/{len(self.data)}\n"
        stats_text += f"Current Time: {current_time_str}\n"
        stats_text += f"━━━━━━━━━━━━━━━━━━━━\n"
        stats_text += f"Opening: {current_data['Close'].iloc[0]:,.0f}\n"
        stats_text += f"Current: {current_data['Close'].iloc[-1]:,.0f}\n"
        stats_text += f"Change: {price_change:+.0f} points\n"
        stats_text += f"━━━━━━━━━━━━━━━━━━━━\n"
        stats_text += f"MAX: {max_high:,.0f} @ {max_time}\n"
        stats_text += f"MIN: {min_low:,.0f} @ {min_time}\n"
        stats_text += f"Range: {(max_high - min_low):.0f} points\n"
        stats_text += f"━━━━━━━━━━━━━━━━━━━━\n"
        stats_text += f"Signals: {len(self.state.detected_buy_signals)} BUY, {len(self.state.detected_sell_signals)} SELL"
        
        self.stats_box.set_text(stats_text)
        
        current_time_display = times[-1].strftime('%H:%M:%S')
        self.current_time_text.set_text(f"Viewing: {current_time_display}")
    
    def update_pl_axis(self, current_data):
        """Update profit/loss axis"""
        self.ax_top.clear()
        self.ax_top.set_xlim(self.ax.get_xlim())
        self.ax_top.set_ylim(self.ax.get_ylim())
        self.ax_top.set_xlabel('P/L by Minute (after trade)', fontsize=11, fontweight='bold')
        self.ax_top.xaxis.set_label_position('top')
        self.ax_top.tick_params(axis='x', which='both', top=True, bottom=False, labeltop=True, labelbottom=False)
    
    def save_snapshot(self, current_data):
        """Save snapshot at specific times"""
        snapshot_times = ['09:31', '09:38', '09:45', '09:55', '10:00']
        current_time_hhmm = current_data.index[-1].strftime('%H:%M')
        
        if current_time_hhmm in snapshot_times and current_time_hhmm not in self.state.snapshots_taken:
            timestamp_filename = current_data.index[-1].strftime('%Y%m%d_%H%M')
            snapshot_filename = f"{self.output_dir}/YM_{self.target_date}_{timestamp_filename}.png"
            self.fig.savefig(snapshot_filename, dpi=300, bbox_inches='tight')
            self.state.snapshots_taken.add(current_time_hhmm)
            print(f"  📸 Snapshot: {snapshot_filename}")
    
    def create_navigation_buttons(self):
        """Create navigation buttons"""
        ax_start = plt.axes([0.1, 0.02, 0.1, 0.04])
        ax_back = plt.axes([0.22, 0.02, 0.1, 0.04])
        ax_forward = plt.axes([0.34, 0.02, 0.1, 0.04])
        ax_end = plt.axes([0.46, 0.02, 0.1, 0.04])
        ax_play = plt.axes([0.58, 0.02, 0.1, 0.04])
        
        self.btn_start = Button(ax_start, '<< Start')
        self.btn_back = Button(ax_back, '< Back')
        self.btn_forward = Button(ax_forward, 'Forward >')
        self.btn_end = Button(ax_end, 'End >>')
        self.btn_play = Button(ax_play, 'Play')
        
        self.btn_start.on_clicked(self.on_start)
        self.btn_back.on_clicked(self.on_back)
        self.btn_forward.on_clicked(self.on_forward)
        self.btn_end.on_clicked(self.on_end)
        self.btn_play.on_clicked(self.on_play)
    
    def on_start(self, event):
        self.state.is_playing = False
        if self.state.timer:
            self.state.timer.stop()
        self.state.current_frame = 0
        self.update_plot(self.state.current_frame)
        self.fig.canvas.draw()
        self.fig.canvas.flush_events()
    
    def on_back(self, event):
        self.state.is_playing = False
        if self.state.timer:
            self.state.timer.stop()
        if self.state.current_frame > 0:
            self.state.current_frame -= 1
            self.update_plot(self.state.current_frame)
            self.fig.canvas.draw()
            self.fig.canvas.flush_events()
    
    def on_forward(self, event):
        self.state.is_playing = False
        if self.state.timer:
            self.state.timer.stop()
        if self.state.current_frame < len(self.data) - 1:
            self.state.current_frame += 1
            self.update_plot(self.state.current_frame)
            self.fig.canvas.draw()
            self.fig.canvas.flush_events()
    
    def on_end(self, event):
        self.state.is_playing = False
        if self.state.timer:
            self.state.timer.stop()
        self.state.current_frame = len(self.data) - 1
        self.update_plot(self.state.current_frame)
        self.fig.canvas.draw()
        self.fig.canvas.flush_events()

    def on_play(self, event):
        if self.state.is_playing:
            self.state.is_playing = False
            if self.state.timer:
                self.state.timer.stop()
            self.btn_play.label.set_text('Play')
            self.fig.canvas.draw()
        else:
            self.state.is_playing = True
            self.btn_play.label.set_text('Pause')
            self.fig.canvas.draw()
            self.play_animation()
    
    def play_animation(self):
        if self.state.is_playing and self.state.current_frame < len(self.data) - 1:
            self.state.current_frame += 1
            self.update_plot(self.state.current_frame)
            self.fig.canvas.draw()
            self.fig.canvas.flush_events()
            self.state.timer = self.fig.canvas.new_timer(interval=500)
            self.state.timer.single_shot = True
            self.state.timer.add_callback(self.play_animation)
            self.state.timer.start()
        else:
            self.state.is_playing = False
            self.btn_play.label.set_text('Play')
            self.fig.canvas.draw()
    
    def show(self):
        """Display the interactive plot"""
        self.create_figure()
        self.detect_all_signals_once()
        self.update_plot(0)
        self.create_navigation_buttons()
        self.fig.canvas.draw()
        # Detect all signals ONCE before showing the graph
        print(f"\n✓ Interactive graph ready!")
        print(f"  - Total minutes: {len(self.data)}")
        print(f"  - Use buttons to navigate\n")
        plt.show()


