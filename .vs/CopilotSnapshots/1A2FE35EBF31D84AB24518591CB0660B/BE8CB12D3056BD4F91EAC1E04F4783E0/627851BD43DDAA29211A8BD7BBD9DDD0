"""
Split 'CBOT_MINI_YM1!, 1 (2).csv' into per-day CSVs for 10:30-11:00am.
Source: Desktop/CBOT_MINI_YM1!, 1 (2).csv
Output folder: Desktop/CBOT_MINI_YM1_ByDate_1030_1100
Each file: CBOT_MINI_YM1_YYYY-MM-DD.csv
"""
import os
import pandas as pd

home = os.path.expanduser("~")
desktop = os.path.join(home, "Desktop")

source_csv = os.path.join(desktop, "CBOT_MINI_YM1!, 1 (2).csv")
out_dir = os.path.join(desktop, "CBOT_MINI_YM1_ByDate_1030_1100")
os.makedirs(out_dir, exist_ok=True)

print("=" * 60)
print("Splitting CBOT_MINI_YM1!, 1 (2).csv by Date (10:30-11:00am)")
print("=" * 60)
print(f"Source:  {source_csv}")
print(f"Output:  {out_dir}")

if not os.path.exists(source_csv):
    print("ERROR: source CSV not found.")
    raise SystemExit(1)

print("\nLoading data...")
df = pd.read_csv(source_csv)
print(f"Rows: {len(df):,}")
print(f"Columns: {df.columns.tolist()}")

if "time" not in df.columns:
    print("ERROR: expected 'time' column not found.")
    raise SystemExit(1)

print("Parsing time column...")
df["time"] = pd.to_datetime(df["time"], errors="coerce", utc=True)
import pytz
eastern = pytz.timezone("US/Eastern")
df["time"] = df["time"].dt.tz_convert(eastern)
before = len(df)
df = df.dropna(subset=["time"]).copy()
after = len(df)
if after != before:
    print(f"Dropped {before - after} rows with invalid timestamps")

df["Date"] = df["time"].dt.date.astype(str)
df["Hour"] = df["time"].dt.hour
df["Minute"] = df["time"].dt.minute

unique_dates = sorted(df["Date"].unique())
print(f"Unique dates: {len(unique_dates)}")

files_written = 0
for d in unique_dates:
    day_df = df[df["Date"] == d].copy()
    if day_df.empty:
        continue
    # Strict filter for 10:30:00 to 11:00:00 inclusive
    day_df = day_df[(day_df["time"].dt.time >= pd.to_datetime("10:30:00").time()) & (day_df["time"].dt.time <= pd.to_datetime("11:00:00").time())]
    if day_df.empty:
        continue
    # Drop helper columns
    day_df = day_df.drop(columns=["Date", "Hour", "Minute"])
    fname = f"CBOT_MINI_YM1_{d}.csv"
    out_path = os.path.join(out_dir, fname)
    day_df.to_csv(out_path, index=False)
    files_written += 1
    # Print first and last timestamp for verification
    first_ts = day_df["time"].iloc[0] if len(day_df) > 0 else None
    last_ts = day_df["time"].iloc[-1] if len(day_df) > 0 else None
    print(f"  Wrote {len(day_df):5d} rows -> {fname} | First: {first_ts} Last: {last_ts}")

print("\n" + "=" * 60)
print("Done")
print("=" * 60)
print(f"Total days:   {len(unique_dates)}")
print(f"Files written: {files_written}")
print(f"Output folder: {out_dir}")
